# Copy to ~/.em_celery/config.ini (install.sh does this on first deploy).
# Legacy em-celery uses the same path for Admin user.

[celery]
# Broker for senders/workers when BROKER_URL is not set.
broker_url = redis://127.0.0.1:6379/0

[spapi]
lwa_refresh_token = CHANGEME
lwa_client_id = CHANGEME
lwa_client_secret = CHANGEME
aws_access_key = CHANGEME
aws_secret_key = CHANGEME

[product_service]
host = 127.0.0.1
port = 9200
user =
password =

[offer_service]
host = 127.0.0.1
port = 9200
user =
password =

[telegram]
api_token = CHANGEME
group_chat_id = CHANGEME

[sentry]
dsn =
traces_sample_rate = 0.1
profiles_sample_rate = 0.0

[logging]
level = INFO
