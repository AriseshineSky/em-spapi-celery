# Copy to ~/.em_celery/config.ini (install.sh does this on first deploy).
# Legacy em-celery uses the same path for Admin user.
#
# Broker: set BROKER_URL in /etc/conf.d/em_celery or the process environment.
# Elasticsearch cluster: 7.17.10 (product_service + offer_service)

[spapi]
lwa_refresh_token = CHANGEME
lwa_client_id = CHANGEME
lwa_client_secret = CHANGEME
aws_access_key = CHANGEME
aws_secret_key = CHANGEME

[product_service]
host = 127.0.0.1
port = 9200
user =
password =

[offer_service]
host = 127.0.0.1
port = 9200
user =
password =

[telegram]
api_token = CHANGEME
group_chat_id = CHANGEME

[logging]
level = INFO
